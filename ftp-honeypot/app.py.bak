from pyftpdlib.authorizers import DummyAuthorizer
from pyftpdlib.handlers import FTPHandler
from pyftpdlib.servers import FTPServer
import requests
import os
from pathlib import Path

API_URL = os.getenv("CENTRAL_API_URL", "http://api:8000/events")
FAKE_DIR = Path("/app/fake_files")
FAKE_DIR.mkdir(exist_ok=True)

for name in ["backup.zip", "database.sql", "config.php", "passwords.txt", "company_data.xlsx"]:
    p = FAKE_DIR / name
    if not p.exists():
        p.write_text("dummy honeypot file - no real sensitive data\n")

def send_event(event):
    try:
        requests.post(API_URL, json=event, timeout=3)
    except Exception:
        pass

class HoneypotFTPHandler(FTPHandler):
    def on_connect(self):
        send_event({
            "source_ip": self.remote_ip,
            "source_port": self.remote_port,
            "service": "FTP",
            "event_type": "connect",
            "destination_port": 2121,
            "attack_type": "FTP Probe",
            "risk_score": 20,
            "severity": "Low",
            "raw_log": {"message": "ftp connect"}
        })

    def on_login(self, username):
        send_event({
            "source_ip": self.remote_ip,
            "source_port": self.remote_port,
            "service": "FTP",
            "event_type": "login",
            "destination_port": 2121,
            "username": username,
            "attack_type": "FTP Login Attempt",
            "risk_score": 40,
            "severity": "Medium",
            "raw_log": {"message": "ftp login"}
        })

    def on_file_sent(self, file):
        send_event({
            "source_ip": self.remote_ip,
            "service": "FTP",
            "event_type": "file_download_attempt",
            "destination_port": 2121,
            "path": str(file),
            "attack_type": "Sensitive File Access Attempt",
            "risk_score": 70,
            "severity": "High",
            "raw_log": {"file": str(file)}
        })

    def on_file_received(self, file):
        send_event({
            "source_ip": self.remote_ip,
            "service": "FTP",
            "event_type": "file_upload_attempt",
            "destination_port": 2121,
            "path": str(file),
            "attack_type": "File Upload Attempt",
            "risk_score": 85,
            "severity": "Critical",
            "raw_log": {"file": str(file)}
        })

authorizer = DummyAuthorizer()
authorizer.add_user("admin", "admin123", str(FAKE_DIR), perm="elradfmwMT")
authorizer.add_anonymous(str(FAKE_DIR), perm="elr")

handler = HoneypotFTPHandler
handler.authorizer = authorizer
handler.banner = "Corporate FTP Server Ready"

server = FTPServer(("0.0.0.0", 2121), handler)
print("FTP honeypot running on port 2121")
server.serve_forever()
